#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_build:
	python3 -m build --wheel --no-isolation

override_dh_auto_install:
	install -d debian/npu-proxy/usr/share/npu-proxy/wheels
	cp dist/npu_proxy-*.whl debian/npu-proxy/usr/share/npu-proxy/wheels/
	install -D -m 644 packaging/debian/pip-constraints.txt debian/npu-proxy/usr/share/npu-proxy/constraints.txt
	install -D -m 644 packaging/npu-proxy.service debian/npu-proxy/lib/systemd/system/npu-proxy.service
	install -D -m 644 packaging/npu-proxy.environment debian/npu-proxy/etc/default/npu-proxy

override_dh_installsystemd:
	dh_installsystemd --name=npu-proxy
